# Gmail OAuth (Step 1에서 생성)
GOOGLE_CLIENT_ID=your-client-id
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REFRESH_TOKEN=your-refresh-token

# OpenAI (Parser Agent LLM)
OPENAI_API_KEY=your-openai-key

# PostgreSQL (LangGraph checkpointer + hitl_pending)
DATABASE_URL=postgresql://dairinin:dairinin@localhost:5432/dairinin

# DRY_RUN mode (true = Calendar에 실제 쓰기 안 함)
DRY_RUN=true

